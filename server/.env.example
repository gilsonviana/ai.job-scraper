DEBUG=False
DATABASE_URL=sqlite:///./data.db
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# NLP Models
NLP_MODEL_SPACY=en_core_web_lg
NLP_MODEL_HF_STACK=distilbert-base-uncased-finetuned-sst-2-english
NLP_MODEL_HF_CLASSIFIER=facebook/bart-large-mnli

# NLP Pipeline Constraints
CONFIDENCE_THRESHOLD=0.7
MAX_INPUT_SIZE=51200
EXTRACTION_TIMEOUT=30
MAX_PDF_SIZE=10485760
